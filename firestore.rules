rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function admin() { return signedIn() && profile().data.role == 'admin'; }
    function assigned(cajaId) { return admin() || get(/databases/$(database)/documents/cajas/$(cajaId)).data.usuarioAsignadoId == request.auth.uid; }

    match /settings/general { allow read: if signedIn(); allow write: if admin(); }
    match /users/{userId} {
      allow read: if signedIn() && (admin() || request.auth.uid == userId);
      allow create: if signedIn() && request.auth.uid == userId && request.resource.data.role == 'user';
      allow update: if admin() || (request.auth.uid == userId && request.resource.data.role == resource.data.role);
      allow delete: if false;
    }
    match /cajas/{cajaId} {
      allow read: if signedIn() && (admin() || resource.data.usuarioAsignadoId == request.auth.uid);
      allow create: if admin() && request.resource.data.usuarioInicioId == request.auth.uid;
      allow update: if signedIn() && assigned(cajaId) && request.resource.data.usuarioInicioId == resource.data.usuarioInicioId;
      allow delete: if false;
    }
    match /{collectionName}/{documentId} {
      allow read, create, update: if signedIn() && collectionName in ['nominaciones', 'retiros', 'entradas'] && assigned(request.resource.data.cajaId);
      allow delete: if false;
    }
  }
}
